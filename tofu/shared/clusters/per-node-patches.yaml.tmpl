# Per-machine ConfigPatch resource — applied via `omnictl apply` by
# the sync-cluster-template workflow, one resource per node that
# needs a machine-specific Talos patch (today: every Contabo node).
#
# Rendered by Bash (envsubst), NOT by OpenTofu. The ${...} forms
# below are environment-variable references resolved at workflow
# runtime; tofu never reads this file. Three variables consumed:
#   ID                       unique resource id (e.g. stawi-<node>-link)
#   TARGET_SELECTORS_BLOCK   pre-rendered YAML list-of-strings, 4-space indent
#   INDENTED_DATA            pre-rendered Talos patch body, 4-space indent
#
# `target_label_selectors` is an array of label-equality predicates;
# Omni binds the patch to whichever Machine carries ALL the listed
# labels. The selectors carry the per-node binding; the
# `omni.sidero.dev/cluster: stawi` label is deliberately NOT set —
# it would cause `omnictl cluster template sync` to claim ownership
# of these per-node patches and prune them as "not in template" on
# the next sync run, breaking Contabo node networking. Selectors
# alone keep the patch attached to the right Machine; the resource
# sits outside any cluster template's ownership scope.
#
# `data` carries the multi-doc Talos config patch verbatim. The
# rendered file is fed to `omnictl apply -f <path>` (omnictl rejects
# stdin in v1.7.x — must be a real file).
metadata:
  namespace: default
  type: ConfigPatches.omni.sidero.dev
  id: ${ID}
  labels:
    stawi.local/per-node-link: "true"
spec:
  target_label_selectors:
${TARGET_SELECTORS_BLOCK}
  data: |
${INDENTED_DATA}
